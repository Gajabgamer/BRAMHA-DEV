PORT=8000
REDIS_URL=redis://localhost:6379

APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

AI_CHAT_RATE_LIMIT_MAX=8
AI_CHAT_RATE_LIMIT_WINDOW_MS=600000

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/integrations/gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/integrations/google-calendar/callback

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/integrations/github/callback

MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
OUTLOOK_REDIRECT_URI=http://localhost:8000/api/integrations/outlook/callback

OAUTH_STATE_SECRET=replace-with-a-strong-random-secret
